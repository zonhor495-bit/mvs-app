{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "allowImportingTsExtensions": false,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": "build/electron",
    "rootDir": "electron",
    "noEmit": false,
    "isolatedModules": false,
    "types": ["node"]
  },
  "include": ["electron"]
}
